# Unity Client Gitignore (Relative to client/ directory)

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/Memory.json
/memory.json
/Assets/AssetStoreTools*

# Autogenerated VS/MD/Consulo solution and project files
/*.csproj
/*.unityproj
/*.sln
/*.suo
/*.tmp
/*.user
/*.userprefs
/*.pidb
/*.booproj
/*.svd
/*.pdb
/*.opendb
/*.db

# Unity WebGL Build folders
/Assets/PlayServicesResolver/
/Assets/Plugins/Android/assets/

# Crash reports
/sysinfo.txt

# Addressables generated files
/Assets/AddressableAssetsData/*_Mobile/
/Assets/AddressableAssetsData/*_PC/
/Assets/StreamingAssets/aa/*

# Nuget package files
/NuGet/
/packages/
