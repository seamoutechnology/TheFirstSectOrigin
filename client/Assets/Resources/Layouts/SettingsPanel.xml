<Layout name="SettingsPanel">
    <Panel name="MainBg" anchorMin="0.5,0.5" anchorMax="0.5,0.5" size="600,800" color="#2C3E50">
        
        <Text name="Title" content="ui_settings_title" localized="true" position="0, 350" fontSize="32" style="TitleText" />

        <!-- Language Selection -->
        <Panel name="LanguageGroup" position="0, 100" size="500, 100">
            <Text name="LblLang" content="ui_settings_lang" localized="true" position="-150, 0" fontSize="24" />
            <Button name="BtnLangVi" text="Tiếng Việt" position="50, 0" size="120, 50" onClick="OnLanguageViClicked" />
            <Button name="BtnLangEn" text="English" position="180, 0" size="120, 50" onClick="OnLanguageEnClicked" />
        </Panel>

        <!-- Close Button -->
        <Button name="BtnClose" text="ui_close" localized="true" position="0, -350" size="200, 60" onClick="CloseSettings" style="SecondaryButton" />

    </Panel>
</Layout>
