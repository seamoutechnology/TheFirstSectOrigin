<Layout name="BattleGrid">
    <!-- Container cho bàn cờ, căn giữa màn hình -->
    <Panel name="GridContainer" anchorMin="0.5,0.5" anchorMax="0.5,0.5" size="800,800" color="#00000044">
        
        <!-- Hàng 1 -->
        <Panel name="Slot_0_0" position="-300, 300" size="180,180" style="GridSlot" />
        <Panel name="Slot_1_0" position="-100, 300" size="180,180" style="GridSlot" />
        <Panel name="Slot_2_0" position="100, 300" size="180,180" style="GridSlot" />
        <Panel name="Slot_3_0" position="300, 300" size="180,180" style="GridSlot" />

        <!-- Hàng 2 -->
        <Panel name="Slot_0_1" position="-300, 100" size="180,180" style="GridSlot" />
        <Panel name="Slot_1_1" position="-100, 100" size="180,180" style="GridSlot" />
        <Panel name="Slot_2_1" position="100, 100" size="180,180" style="GridSlot" />
        <Panel name="Slot_3_1" position="300, 100" size="180,180" style="GridSlot" />

        <!-- Hàng 3 -->
        <Panel name="Slot_0_2" position="-300, -100" size="180,180" style="GridSlot" />
        <Panel name="Slot_1_2" position="-100, -100" size="180,180" style="GridSlot" />
        <Panel name="Slot_2_2" position="100, -100" size="180,180" style="GridSlot" />
        <Panel name="Slot_3_2" position="300, -100" size="180,180" style="GridSlot" />

        <!-- Hàng 4 -->
        <Panel name="Slot_0_3" position="-300, -300" size="180,180" style="GridSlot" />
        <Panel name="Slot_1_3" position="-100, -300" size="180,180" style="GridSlot" />
        <Panel name="Slot_2_3" position="100, -300" size="180,180" style="GridSlot" />
        <Panel name="Slot_3_3" position="300, -300" size="180,180" style="GridSlot" />

    </Panel>
</Layout>
