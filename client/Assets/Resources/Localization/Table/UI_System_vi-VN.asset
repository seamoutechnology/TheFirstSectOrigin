  m_TableData:
  - m_Id: 9987138523136
    m_Localized: "\u1EA8n"
    m_Metadata:
      m_Items: []
  - m_Id: 28099351154688
    m_Localized: "Ho\xE0n t\u1EA5t! \u0110ang v\xE0o game..."
    m_Metadata:
      m_Items: []
  - m_Id: 28085220544512
    m_Localized: "\u0110ang t\u1ED1i \u01B0u \u0111\u1ED3 h\u1ECDa..."
    m_Metadata:
      m_Items: []
  - m_Id: 28060931330048
    m_Localized: "\u0110ang ki\u1EC3m tra phi\xEAn b\u1EA3n c\u1EADp nh\u1EADt..."
    m_Metadata:
      m_Items: []
  - m_Id: 28021794279424
    m_Localized: "\u0110ang t\u1ED1i \u01B0u c\u1EA5u h\xECnh m\xE1y..."
    m_Metadata:
      m_Items: []
  - m_Id: 193684781404160
    m_Localized: "T\xEAn t\xE0i kho\u1EA3n"
    m_Metadata:
      m_Items: []
  - m_Id: 193837063999488
    m_Localized: "M\u1EADt kh\u1EA9u"
    m_Metadata:
      m_Items: []
  - m_Id: 194062939852800
    m_Localized: "\u0110\u0103ng nh\u1EADp"
    m_Metadata:
      m_Items: []
  - m_Id: 194128861728768
    m_Localized: "\u0110\u0103ng k\xFD"
    m_Metadata:
      m_Items: []
  - m_Id: 407966399860736
    m_Localized: "Hi\u1EC7n m\u1EADt kh\u1EA9u"
    m_Metadata:
      m_Items: []
  - m_Id: 412479986864128
    m_Localized: "Ch\xE0o m\u1EEBng \u0111\u1EA1o h\u1EEFu tr\u1EDF l\u1EA1i,\\n<color=#FFD700>{0}</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 412687353253888
    m_Localized: "Ng\u01B0\u1EDDi ch\u01A1i"
    m_Metadata:
      m_Items: []
  - m_Id: 515714315718656
    m_Localized: "H\xF2m th\u01B0 \u0111i\u1EC7n t\u1EED"
    m_Metadata:
      m_Items: []
  - m_Id: 515866933858304
    m_Localized: "T\xEAn t\xE0i kho\u1EA3n m\u1EDBi"
    m_Metadata:
      m_Items: []
  - m_Id: 516131535720448
    m_Localized: "M\u1EADt kh\u1EA9u m\u1EDBi c\u1EE7a b\u1EA1n"
    m_Metadata:
      m_Items: []
  - m_Id: 517060775383040
    m_Localized: "Nh\u1EADp l\u1EA1i m\u1EADt kh\u1EA9u m\u1EDBi c\u1EE7a b\u1EA1n"
    m_Metadata:
      m_Items: []
  - m_Id: 551987667537920
    m_Localized: "\u0110ang x\xE1c th\u1EF1c danh t\xEDnh..."
    m_Metadata:
      m_Items: []
  - m_Id: 3015083591348224
    m_Localized: '           '
    m_Metadata:
      m_Items: []
  - m_Id: 3135373319221248
    m_Localized: "Vui l\xF2ng nh\u1EADp \u0111\u1EA7y \u0111\u1EE7 th\xF4ng tin."
    m_Metadata:
      m_Items: []
  - m_Id: 3135904552988672
    m_Localized: "L\u1ED7i kh\xF4ng x\xE1c \u0111\u1ECBnh."
    m_Metadata:
      m_Items: []
  - m_Id: 3136037814415360
    m_Localized: "L\u1ED7i k\u1EBFt n\u1ED1i t\u1EDBi m\xE1y ch\u1EE7."
    m_Metadata:
      m_Items: []
  - m_Id: 3473400180649984
    m_Localized: "T\xE0i kho\u1EA3n"
    m_Metadata:
      m_Items: []
  - m_Id: 5320193770786816
    m_Localized: "Th\xF4ng b\xE1o"
    m_Metadata:
      m_Items: []
  - m_Id: 5320361685553152
    m_Localized: "Kh\u1EDFi h\xE0nh"
    m_Metadata:
      m_Items: []
  - m_Id: 5323293034287104
    m_Localized: "Phi\xEAn b\u1EA3n tr\xF2 ch\u01A1i:"
    m_Metadata:
      m_Items: []
  - m_Id: 5323410080534528
    m_Localized: "Ch\u1ECDn m\xE1y ch\u1EE7"
    m_Metadata:
      m_Items: []
  - m_Id: 5440729108713472
    m_Localized: "\u0110\u1EC1 c\u1EED"
    m_Metadata:
      m_Items: []
  - m_Id: 5545653230374912
    m_Localized: "\u0110\u1EC1 c\u1EED"
    m_Metadata:
      m_Items: []
  - m_Id: 5545738743844864
    m_Localized: "\u0110\xE3 c\xF3 nh\xE2n v\u1EADt"
    m_Metadata:
      m_Items: []
  - m_Id: 5545823674306560
    m_Localized: "C\u1EE5m M\u1EDBi Nh\u1EA5t"
    m_Metadata:
      m_Items: []
  - m_Id: 6329291035381760
    m_Localized: "C\u1EE5m"
    m_Metadata:
      m_Items: []
  - m_Id: 6331742673178624
    m_Localized: "\u0110ang m\u1EDF"
    m_Metadata:
      m_Items: []
  - m_Id: 6374552877142016
    m_Localized: "[Quy \u0111\u1ECBnh]"
    m_Metadata:
      m_Items: []
  - m_Id: 6374557650259968
    m_Localized: "[B\u1EA3o tr\xEC]"
    m_Metadata:
      m_Items: []
  - m_Id: 6374559290232832
    m_Localized: "[S\u1EF1 Ki\u1EC7n]"
    m_Metadata:
      m_Items: []
  - m_Id: 6377337089691648
    m_Localized: "[Tin T\u1EE9c]"
    m_Metadata:
      m_Items: []
  - m_Id: 6377210094555136
    m_Localized: "\u0110ang t\u1EA3i th\xF4ng b\xE1o..."
    m_Metadata:
      m_Items: []
  - m_Id: 6377252486385664
    m_Localized: "Th\xF4ng b\xE1o"
    m_Metadata:
      m_Items: []
  - m_Id: 6377290293841920
    m_Localized: "Hi\u1EC7n t\u1EA1i kh\xF4ng c\xF3 th\xF4ng b\xE1o n\xE0o."
    m_Metadata:
      m_Items: []
  - m_Id: 7031011717681152
    m_Localized: "C\u1EA5p \u0111\u1ED9: {0}"
    m_Metadata:
      m_Items: []
  - m_Id: 7031081536065536
    m_Localized: "T\xF4ng m\xF4n: {0}"
    m_Metadata:
      m_Items: []
  - m_Id: 7031144047972352
    m_Localized: "M\xE1y ch\u1EE7: {0}"
    m_Metadata:
      m_Items: []
  - m_Id: 7031176113426432
    m_Localized: "Ch\u01B0a k\u1EBFt n\u1ED1i"
    m_Metadata:
      m_Items: []
  - m_Id: 7031246170886144
    m_Localized: "Th\u1EDDi gian ch\u01A1i: <color=yellow>{0} ph\xFAt\\n<size=80%>(Khuy\u1EBFn
      c\xE1o: Ch\u01A1i qu\xE1 180 ph\xFAt \u1EA3nh h\u01B0\u1EDFng s\u1EE9c kh\u1ECFe)"
    m_Metadata:
      m_Items: []
  - m_Id: 7031326038822912
    m_Localized: "T\xEDnh n\u0103ng \u0111ang ph\xE1t tri\u1EC3n!"
    m_Metadata:
      m_Items: []
  - m_Id: 7031283152064512
    m_Localized: "L\u1ED7i k\u1EBFt n\u1ED1i Server!"
    m_Metadata:
      m_Items: []
  - m_Id: 7031307940401152
    m_Localized: "Th\xF4ng b\xE1o"
    m_Metadata:
      m_Items: []
  - m_Id: 7033257796833280
    m_Localized: "N\u1EA1p ti\u1EC1n"
    m_Metadata:
      m_Items: []
  - m_Id: 7033290353020928
    m_Localized: "\u0110\u1ED5i m\xE3"
    m_Metadata:
      m_Items: []
  - m_Id: 7033299723096064
    m_Localized: "\u0110\u0103ng xu\u1EA5t"
    m_Metadata:
      m_Items: []
  - m_Id: 7055658714664960
    m_Localized: "ID T\xE0i kho\u1EA3n: {0}"
    m_Metadata:
      m_Items: []
  - m_Id: 7055701223936000
    m_Localized: "Ph\xE2n quy\u1EC1n: {0}"
    m_Metadata:
      m_Items: []
  - m_Id: 7057148636303360
    m_Localized: "\u0110\xE3 sao ch\xE9p:"
    m_Metadata:
      m_Items: []
  - m_Id: 7827532046405632
    m_Localized: "C\xF3 ch\u1EE9a n\u1ED9i dung y\xEAu c\u1EA7u ng\u01B0\u1EDDi d\xF9ng
      \u0111\u1EE7 18 tu\u1ED5i"
    m_Metadata:
      m_Items: []
  - m_Id: 7827797944307712
    m_Localized: "Ch\u01A1i qu\xE1 180 ph\xFAt m\u1ED9t ng\xE0y g\xE2y h\u1EA1i cho
      s\u1EE9c kh\u1ECFe c\u1EE7a b\u1EA1n"
    m_Metadata:
      m_Items: []
  - m_Id: 7828083136008192
    m_Localized: Nam
    m_Metadata:
      m_Items: []
  - m_Id: 7828135912935424
    m_Localized: "N\u1EEF"
    m_Metadata:
      m_Items: []
  - m_Id: 7862249089142784
    m_Localized: "Ng\u1EABu nhi\xEAn"
    m_Metadata:
      m_Items: []
  - m_Id: 8003371698491392
    m_Localized: "Nh\u1EADp t\xEAn ng\u01B0\u1EDDi ch\u01A1i"
    m_Metadata:
      m_Items: []
  - m_Id: 8860006387249152
    m_Localized: Xem
    m_Metadata:
      m_Items: []
  - m_Id: 8860136515530752
    m_Localized: "N\xE2ng c\u1EA5p"
    m_Metadata:
      m_Items: []
  - m_Id: 8861390121693184
    m_Localized: "Nh\u1EADn"
    m_Metadata:
      m_Items: []
  - m_Id: 8861462922227712
    m_Localized: "B\u1ECF qua"
    m_Metadata:
      m_Items: []
  - m_Id: 8861555251441664
    m_Localized: "S\u1EEDa"
    m_Metadata:
      m_Items: []
  - m_Id: 8861653452681216
    m_Localized: "H\u1EE7y"
    m_Metadata:
      m_Items: []
  - m_Id: 8861726181912576
    m_Localized: "Di chuy\u1EC3n"
    m_Metadata:
      m_Items: []
  - m_Id: 8861808918753280
    m_Localized: "Ph\xE1 h\u1EE7y"
    m_Metadata:
      m_Items: []
  - m_Id: 8861883984211968
    m_Localized: "\u0110\xF3ng"
    m_Metadata:
      m_Items: []
  - m_Id: 8996909539356672
    m_Localized: "\u0110\u1EB7t"
    m_Metadata:
      m_Items: []
  - m_Id: 8996955185967104
    m_Localized: "H\u1EE7y"
    m_Metadata:
      m_Items: []
  - m_Id: 9174730983305216
    m_Localized: "Th\u1EDDi gian n\xE2ng c\u1EA5p"
    m_Metadata:
      m_Items: []
  - m_Id: 9179693801238528
    m_Localized: "Ti\xEAu t\u1ED1n"
    m_Metadata:
      m_Items: []
  - m_Id: 9180525552693248
    m_Localized: "\u0110\xE3 \u0111\u1EA1t c\u1EA5p t\u1ED1i \u0111a"
    m_Metadata:
      m_Items: []
  - m_Id: 9181582475358208
    m_Localized: " Nh\xE0 Ch\xEDnh"
    m_Metadata:
      m_Items: []
  - m_Id: 9182657081208832
    m_Localized: "Linh Ti\xEAu \u0110i\u1EC7n: N\u1EB1m tr\xEAn \u0111\u1EC9nh n\xFAi
      cao nh\u1EA5t, quanh n\u0103m m\xE2y ph\u1EE7 v\xE0 d\u1ED3i d\xE0o linh kh\xED.
      N\u01A1i \u0111\xE2y v\u1EEBa l\xE0 trung t\xE2m \u0111i\u1EC1u h\xE0nh, v\u1EEBa
      l\xE0 m\u1EAFt tr\u1EADn t\u1EE5 linh c\u1EE7a to\xE0n t\xF4ng m\xF4n."
    m_Metadata:
      m_Items: []
  - m_Id: 9199103047856128
    m_Localized: "Th\xE0nh c\xF4ng"
    m_Metadata:
      m_Items: []
  - m_Id: 9229031172698112
    m_Localized: "\u0110\u0103ng k\xFD th\xE0nh c\xF4ng!"
    m_Metadata:
      m_Items: []
  - m_Id: 9634828327284736
    m_Localized: "N\xF4ng tr\u1EA1i"
    m_Metadata:
      m_Items: []
  - m_Id: 9718650465120256
    m_Localized: "N\xE2ng c\u1EA5p th\xE0nh c\xF4ng"
    m_Metadata:
      m_Items: []
  - m_Id: 9722690162880512
    m_Localized: "C\u1EA5p t\u1ED1i \u0111a"
    m_Metadata:
      m_Items: []
  - m_Id: 9722811839639552
    m_Localized: "Di chuy\u1EC3n"
    m_Metadata:
      m_Items: []
  - m_Id: 9920520865411072
    m_Localized: "Th\xF4ng b\xE1o: {o}"
    m_Metadata:
      m_Items: []
  - m_Id: 9938452936880128
    m_Localized: "X\xE2y d\u1EF1ng"
    m_Metadata:
      m_Items: []
  - m_Id: 9940257951412224
    m_Localized: "Th\u1EBF gi\u1EDBi"
    m_Metadata:
      m_Items: []
  - m_Id: 10032405560389632
    m_Localized: "\u0110\u1ED9ng ph\u1EE7"
    m_Metadata:
      m_Items: []
  - m_Id: 10032523021873152
    m_Localized: "N\u01A1i y\xEAn t\u0129nh \u0111\u1EC3 c\xE1c tu s\u0129 b\u1EBF
      quan t\u1ECFa c\u1EA3ng v\xE0 \u0111\u1ED9t ph\xE1 c\u1EA3nh gi\u1EDBi. N\xE2ng
      c\u1EA5p n\u01A1i n\xE0y gi\xFAp t\u0103ng t\u1ED1c \u0111\u1ED9 h\u1EA5p th\u1EE5
      linh kh\xED t\u1EF1 nhi\xEAn."
    m_Metadata:
      m_Items: []
  - m_Id: 10064986314076160
    m_Localized: "S\u1EA3n xu\u1EA5t"
    m_Metadata:
      m_Items: []
  - m_Id: 10064993826074624
    m_Localized: "C\u01A1 s\u1EDF"
    m_Metadata:
      m_Items: []
  - m_Id: 10065041896992768
    m_Localized: "C\u1EEDa hi\u1EC7u"
    m_Metadata:
      m_Items: []
  - m_Id: 10065068623097856
    m_Localized: "Phong c\u1EA3nh"
    m_Metadata:
      m_Items: []
  - m_Id: 10065090894852096
    m_Localized: "\u0110\xE3 s\u1EDF h\u1EEFu"
    m_Metadata:
      m_Items: []
  - m_Id: 10113704664985600
    m_Localized: "Ch\u1ECDn v\u1ECB tr\xED m\u1EDBi"
    m_Metadata:
      m_Items: []
  - m_Id: 10245392921489408
    m_Localized: "Kh\xF4ng"
    m_Metadata:
      m_Items: []
  - m_Id: 10245503663697920
    m_Localized: "\u0110\u1ED3ng \xFD"
    m_Metadata:
      m_Items: []
  - m_Id: 10245569652682752
    m_Localized: "C\u1EA5t"
    m_Metadata:
      m_Items: []
  - m_Id: 10245736153968640
    m_Localized: "B\u1EA1n c\xF3 mu\u1ED1n c\u1EA5t v\xE0o kho kh\xF4ng?"
    m_Metadata:
      m_Items: []
  - m_Id: 10300925422563328
    m_Localized: "\xC2m l\u01B0\u1EE3ng ch\xEDnh"
    m_Metadata:
      m_Items: []
  - m_Id: 10301984601763840
    m_Localized: "\xC2m nh\u1EA1c"
    m_Metadata:
      m_Items: []
  - m_Id: 10302057888837632
    m_Localized: SFX
    m_Metadata:
      m_Items: []
  - m_Id: 10304074506006528
    m_Localized: "T\u1EAFt \xE2m thanh"
    m_Metadata:
      m_Items: []
  - m_Id: 10304195985633280
    m_Localized: "T\u1EAFt nh\u1EA1c"
    m_Metadata:
      m_Items: []
  - m_Id: 10304249047773184
    m_Localized: "T\u1EAFt SFX"
    m_Metadata:
      m_Items: []
  - m_Id: 10307279960895488
    m_Localized: "C\xE0i \u0111\u1EB7t"
    m_Metadata:
      m_Items: []
  - m_Id: 10314167674957824
    m_Localized: "\u0110\u1EC7 t\u1EED"
    m_Metadata:
      m_Items: []
  - m_Id: 10314172250943488
    m_Localized: "T\xFAi \u0111\u1ED3"
    m_Metadata:
      m_Items: []
  - m_Id: 10314942543261696
    m_Localized: "Ch\u1ECDn ng\xF4n ng\u1EEF"
    m_Metadata:
      m_Items: []
  - m_Id: 10485400186089472
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 1000100
    m_Localized: "C\u1EA5p"
    m_Metadata:
      m_Items: []
  - m_Id: 1000101
    m_Localized: "Thi\xEAn ph\xFA"
    m_Metadata:
      m_Items: []
  - m_Id: 1000102
    m_Localized: "Lo\u1EA1i: {0}"
    m_Metadata:
      m_Items: []
  - m_Id: 1000103
    m_Localized: "C\u1EA5p d\xF9ng: T\xF4ng M\xF4n C\u1EA5p {0}"
    m_Metadata:
      m_Items: []
  - m_Id: 1000104
    m_Localized: "S\u1EDF h\u1EEFu: <color=#00FF00>{0}</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 1000105
    m_Localized: "\u0110\u1EA1o C\u1EE5"
    m_Metadata:
      m_Items: []
  - m_Id: 1000106
    m_Localized: "Trang B\u1ECB"
    m_Metadata:
      m_Items: []
  - m_Id: 1000107
