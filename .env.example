# ==============================================================================
# .env.example - Template cấu hình môi trường
# COPY file này thành .env.development / .env.production / .env.sample
# KHÔNG commit file .env thật lên git!
# ==============================================================================

# --- Môi trường ---
APP_ENV=development           # development | production | sample

# --- PostgreSQL (Global DB - Tài khoản & Auth) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=mmo_admin
POSTGRES_PASSWORD=change_me
POSTGRES_DB=mmo_global

# --- PostgreSQL (Game DB - Dữ liệu từng Zone) ---
GAME_DB_HOST=localhost
GAME_DB_PORT=5432
GAME_DB_USER=mmo_game
GAME_DB_PASSWORD=change_me
GAME_DB_NAME=mmo_game_zone1

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- JWT ---
JWT_SECRET=change_me_to_random_secret
JWT_EXPIRE_HOURS=72

# --- Global Login Server ---
LOGIN_SERVER_PORT=50051
LOGIN_SERVER_HOST=0.0.0.0

# --- Gateway Server (Zone 1) ---
GATEWAY_PORT=50052
GATEWAY_HOST=0.0.0.0
GATEWAY_PUBLIC_ADDR=localhost:50052   # Địa chỉ client kết nối vào

# --- World Server (Zone 1) ---
WORLD_SERVER_PORT=50053
WORLD_SERVER_HOST=0.0.0.0

# --- Combat Server (Zone 1) ---
COMBAT_SERVER_PORT=50054
COMBAT_SERVER_HOST=0.0.0.0

# --- Admin Dashboard ---
ADMIN_PORT=8080
ADMIN_SECRET=change_me

# --- Website & Domain ---
WEB_PORT=3000
DOMAIN=sectorigin.com
CDN_DOMAIN=cdn.sectorigin.com

# --- SMTP (Email) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=The First Sect Origin <noreply@sectorigin.com>

# --- Docker ---
COMPOSE_PROJECT_NAME=thefirstsect
