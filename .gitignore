# ==========================================
# Main Project Root Gitignore
# Covers Go Backend (server/) and Unity Client (client/)
# ==========================================

# --- Environment Configurations ---
.env
.env.development
.env.production
.env.sample
.env.local
.env.*
!.env.example

# --- IDE & Editors ---
.idea/
.vscode/
*.suo
*.user
*.userprefs
*.db
*.suo
*.sln
*.csproj
*.unityproj
*.booproj
.utmp/

# --- OS Generated Files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ==========================================
# Unity Client (client/) Specific
# ==========================================
# Standard Unity ignores
client/Library/
client/library/
client/Temp/
client/temp/
client/Obj/
client/obj/
client/Build/
client/build/
client/Builds/
client/builds/
client/Logs/
client/logs/
client/UserSettings/
client/usersettings/
client/Memory.json
client/memory.json
client/Assets/AssetStoreTools*
client/Assets/PlayServicesResolver/
client/Assets/Plugins/Android/assets/
client/sysinfo.txt
client/Assets/AddressableAssetsData/*_Mobile/
client/Assets/AddressableAssetsData/*_PC/
client/Assets/StreamingAssets/aa/*
client/NuGet/
client/packages/
!client/Packages/
!client/Packages/**
client/Packages/nuget-packages/InstalledPackages/

# Autogenerated VS/MD/Consulo solution and project files
client/*.csproj
client/*.unityproj
client/*.sln
client/*.tmp
client/*.user
client/*.userprefs
client/*.pidb
client/*.booproj
client/*.svd
client/*.pdb
client/*.opendb
client/*.db

# ==========================================
# Go Backend (server/) Specific
# ==========================================
# Binaries and templates
server/bin/
server/*.exe
server/*.exe~
server/*.dll
server/*.so
server/*.dylib
server/gateway
server/world-server
server/admin

# Database & log files
server/logs/
server/*.log
server/db/data/
server/memory.json
